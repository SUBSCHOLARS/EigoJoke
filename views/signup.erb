<!DOCTYPE html>
<html lang="ja" class="sign-html">
  <head>
    <meta charset="UTF-8">
    <title>Counting Stars Sign-Up</title>
    <link rel="icon" href="/img/favicon.ico">
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <div class="sign_form">
      <div class="card">
        <div class="title">
          <h3>EIGO JOKE!</h3>
        </div>
        <div>
          <h3 class="title-sign-up">Sign Up</h3>
        </div>
        <form action="/signup" method="post">
          <div>
            <input type="text" name="name" placeholder="username" class="username"></input>
          </div>
            <input type="mail" name="email" placeholder="email" class="email"></input>
          <div>
            <input type="password" name="password" placeholder="password" class="password"></input>
          </div>
          <div>
            <input type="password" name="password-confirm" placeholder="password confirm" class="password"></input>
          </div>
          <input type="submit" value="SIGN UP" class="button"></input>
        </form>
        <p class="footer"><a href="/signin">すでにアカウントを持っている</a></p>
      </div>
    </div>
  </body>
</html>