<!DOCTYPE html>
<html lang="ja">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="/css/style.css">
        <link rel="stylesheet" href="/css/collection.css">
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
        <script src="/js/collection.js" defer></script>
        <title>コレクション</title>
    </head>
    <body>
        <header>
            <h1>JokeEigo!</h1>
            <% if session[:user] %>
                <p style="color: white;"><a href="/users/<%= session[:user] %>"><%= User.find(session[:user]).name %></a></p>
                <a href="/signout">サインアウト</a>
            <% else %>
                <a href="/signin">サインイン</a>
                <a href="/signin">サインアップ</a>
            <% end %>
        </header>
        
        <div class="container">
        <h2 style="text-align: center; margin-bottom: 8px;">キー表現コレクション</h2>
        <p style="text-align: center; font-size: 13px; color: #718096; margin-bottom: 24px;">カードをタップして意味を確認</p>

        <div class="flip-container" onclick="flipCard()">
            <div class="flipper" id="flipper">
                <div class="front">
                    <p style="font-size: 22px; font-weight: bold; color: #2b6cb0; text-align: center;">
                        <%= @current_joke.key_exp %>
                    </p>
                    <p style="font-size: 13px; color: #718096; margin-top: 16px;">タップして確認</p>
                </div>
                <div class="back">
                    <p style="font-size: 18px; font-weight: bold; color: #2b6cb0; text-align: center; margin-bottom: 12px;">
                        <%= @current_joke.key_exp %>
                    </p>
                    <p style="font-size: 15px; text-align: center; margin-bottom: 16px;">
                        <%= @current_joke.translation %>
                    </p>
                    <a href="/jokes/<%= @current_joke.id %>" style="font-size: 13px;">元のジョークを見る →</a>
                </div>
            </div>
        </div>

        <div class="nav-buttons">
            <% if @prev_joke %>
                <a href="/users/<%= @user.id %>/collection/<%= @prev_joke.id %>">
                    <button class="nav-btn">‹</button>
                </a>
            <% else %>
                <button class="nav-btn" disabled>‹</button>
            <% end %>

            <span class="counter"><%= @current_index + 1 %> / <%= @faved_jokes.length %></span>

            <% if @next_joke %>
                <a href="/users/<%= @user.id %>/collection/<%= @next_joke.id %>">
                    <button class="nav-btn">›</button>
                </a>
            <% else %>
                <button class="nav-btn" disabled>›</button>
            <% end %>
        </div>
    </div>

    </body>
</html>