<!DOCTYPE html>
<html lang="ja">
    <head>
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Joke Page</title>
        <link rel="stylesheet" href="/css/style.css">
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
        <link rel="icon" href="/img/favicon.ico">
        <script src="/js/font.js"></script>
    </head>
    <body>
        <header>
        <h1>JokeEigo</h1>
            <% if session[:user] %>
                <p style="color: white;"><a href="/users/<%= session[:user] %>"><%= User.find(session[:user]).name %></a></p>
                <a href="/signout">サインアウト</a>
            <% else %>
                <a href="/signin">サインイン</a>
                <a href="/signin">サインアップ</a>
            <% end %>
        </header>
        
        <div class="container">
            <a href="/" style="font-size: 14px;">一覧に戻る</a>
            
            <div class="card" style="margin-top: 16px;">
                <p style="font-size: 18px; font-weight: bold; line-height: 1.8;"><%= @joke.joke %></p>
                <form action="/jokes/<%= @joke.id %>/fav" method="POST" style="margin-top: 12px;">
                    <input type="submit" value="⭐ お気に入り登録" class="btn btn-outline" style="width: auto; padding: 6px 16px; font-size: 13px;">
                </form>
            </div>
        
            <div class="card">
                <button class="btn btn-outline" onclick="toggleSection('translation-section')" style="width: auto; padding: 8px 20px;">
                    訳・解説を見る
                </button>
                <div id="translation-section" class="hidden" style="margin-top: 16px;">
                    <h2 style="margin-bottom: 8px;">日本語訳</h2>
                    <p><%= @joke.translation %></p>

                    <h2 style="margin-top: 16px; margin-bottom: 8px;">💡 解説</h2>
                    <p><%= @joke.explanation %></p>

                    <h2 style="margin-top: 16px; margin-bottom: 8px;">🔑 キー表現</h2>
                    <p><%= @joke.key_exp %></p>
                </div>
            </div>
        
            <div class="card">
                <button class="btn" onclick="toggleSection('answer-section')" style="width: auto; padding: 8px 20px;">
                    ✏️ 日本語訳に挑戦する
                </button>
                <div id="answer-section" class="hidden" style="margin-top: 16px;">
                <% if session[:user] %>
                    <form action="/jokes/<%= @joke.id %>/answer" method="POST">
                        <textarea name="body" placeholder="日本語訳を入力してください"></textarea>
                        <input type="submit" value="提出" class="btn">
                    </form>
                <% if @answers && @answers.any? %>
                <% @answers.each do |answer| %>
                    <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid #e2e8f0;">
                        <p style="font-size: 13px; color: #718096;">あなたの訳</p>
                        <p style="margin-top: 4px;"><%= answer.body %></p>
                        <p style="margin-top: 8px; font-size: 20px; font-weight: bold; color: #2b6cb0;">
                            <%= answer.score %>点
                        </p>
                        <p style="margin-top: 4px; font-size: 14px; color: #4a5568;">
                            <%= answer.comment %>
                        </p>
                    </div>
                <% end %>
                <% end %>
                <% else %>
                    <a href="/signin" class="btn">サインインして挑戦する</a>
                <% end %>
                </div>
            </div>
        </div>
        <script src="/js/joke_show.js"></script>
    </body>
</html>